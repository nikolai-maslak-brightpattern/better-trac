{
  "{{chrome}}.manifest_version": 3,
  "{{firefox}}.manifest_version": 2,
  "icons": {
    "16": "icon/16.png",
    "32": "icon/32.png",
    "48": "icon/48.png",
    "96": "icon/96.png",
    "128": "icon/128.png"
  },
  "{{chrome}}.action": {
      "default_title": "BetterTrac"
  },
  "{{firefox}}.browser_action": {
      "default_title": "BetterTrac"
  },
  "{{chrome}}.background": {
      "service_worker": "src/background/background.ts"
  },
  "{{firefox}}.background": {
      "scripts": ["src/background/background.ts"]
  },
  "{{chrome}}.options_ui": {
      "page": "src/options/options.html",
      "open_in_tab": true
  },
  "{{firefox}}.options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["https://trac.brightpattern.com/*"],
      "js": ["src/content/content.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["scripting", "storage"],
  "host_permissions": ["https://trac.brightpattern.com/*"]
}
